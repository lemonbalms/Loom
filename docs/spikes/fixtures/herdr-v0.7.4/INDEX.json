{
  "herdr_version": "0.7.4",
  "protocol": 16,
  "date": "2026-07-17",
  "platform": "macos-aarch64",
  "socket_path": "/Users/kyoungsiklee/.config/herdr/herdr.sock",
  "socket_mode": "0600 unix domain",
  "license": "AGPL-3.0-or-later + commercial dual (github.com/ogulcancelik/herdr)",
  "github": "https://github.com/ogulcancelik/herdr",
  "install": "curl -fsSL https://herdr.dev/install.sh | sh  -> ~/.local/bin/herdr",
  "framing": {
    "style": "NDJSON (newline-delimited JSON)",
    "request": {
      "required": [
        "id",
        "method",
        "params"
      ],
      "notes": "params required even if empty object"
    },
    "success": {
      "shape": {
        "id": "string",
        "result": "object with type field"
      }
    },
    "error": {
      "shape": {
        "id": "string",
        "error": {
          "code": "string",
          "message": "string"
        }
      }
    },
    "events": {
      "shape": {
        "event": "string",
        "data": "object"
      },
      "notes": "pushed on the same connection after events.subscribe; no output body on pane.agent_status_changed"
    }
  },
  "agent_status_observed": [
    "idle",
    "working",
    "blocked",
    "done",
    "unknown"
  ],
  "pane_report_agent_state_allowed": [
    "idle",
    "working",
    "blocked",
    "unknown"
  ],
  "notes": [
    "done is in AgentStatus enum for observation but pane.report_agent rejects state=done",
    "HERDR_PANE_ID is auto-injected (=pane_id)",
    "agent.start env map is applied (LOOM_CARD observed in pane)",
    "agent.send is literal text without Enter (CLI help + live probe)",
    "session.snapshot provides reconcile snapshot (agents/panes/tabs/workspaces)",
    "stale lower seq on pane.report_metadata still returned ok in this probe \u2014 seq semantics need more care for multi-source"
  ],
