  "event_definitions": {
    "pane_agent_detected": {
      "properties": {
        "agent": {
          "type": [
            "string",
            "null"
          ]
        },
        "final_status": {
          "anyOf": [
            {
              "$ref": "#/schemas/event/$defs/AgentStatus"
            },
            {
              "type": "null"
            }
          ]
