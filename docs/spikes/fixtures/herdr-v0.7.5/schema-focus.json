{
  "protocol": 17,
  "schema_version": 1,
  "request_definitions": {
    "TabCreateParams": {
      "properties": {
        "cwd": {
          "type": [
            "string",
            "null"
          ]
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "focus": {
          "default": false,
          "type": "boolean"
        },
        "label": {
          "type": [
            "string",
            "null"
          ]
        },
        "workspace_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "PaneSplitParams": {
      "properties": {
        "cwd": {
          "type": [
            "string",
            "null"
          ]
        },
        "direction": {
          "$ref": "#/schemas/request/$defs/SplitDirection"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "focus": {
          "default": false,
          "type": "boolean"
        },
        "ratio": {
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "target_pane_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "workspace_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "direction"
      ],
      "type": "object"
    },
    "AgentStartParams": {
      "properties": {
