        "pane_id": {
          "type": "string"
        },
        "released": {
          "type": "boolean"
        },
        "type": {
          "const": "pane_agent_detected",
          "type": "string"
        },
        "workspace_id": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "pane_id",
        "workspace_id"
      ],
      "type": "object"
    }
  }
